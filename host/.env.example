# ============================================================
# Host (global) environment variables
# Copy this file to .env and customize. Used by run_post_create.* and run_init_env.*
# ============================================================

# ── Editor ──────────────────────────────────────────────────
# cursor | vscode (for RAG MCP and optional editor-specific defaults)
WHICH_EDITOR=cursor

# ── Git / Terminal ───────────────────────────────────────────
USE_GIT_PROMPT=true
USE_TMUX=true

# ── Docker ──────────────────────────────────────────────────
USE_DOCKER_AUTOCOMPLETE=true

# ── Editor config (Cursor + VSCode user settings) ────────────
USE_VSCODE_CONFIG=true

# ── Claude Code ─────────────────────────────────────────────
USE_CLAUDE_CODE=true
CLAUDE_CODE_CHANNEL=latest
USE_CLAUDE=true
USE_CLAUDE_MARKETPLACE=true

# ── rtk (Rust Token Killer) ──────────────────────────────────
# Reduces LLM token consumption 60–90%; hook in ~/.claude/settings.json
USE_RTK=true

# ── Ollama (local LLM) ───────────────────────────────────────
USE_OLLAMA=false
OLLAMA_REPO=CamillePolice/ollama
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_GPU_ENABLED=auto
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MEMORY_LIMIT=8G

# ── RAG / Supabase ───────────────────────────────────────────
# Set RAG_DSN in .env or export in shell (contains password)
# export RAG_DSN="postgresql://postgres.xxx:xxx@aws-0-eu-west-1.pooler.supabase.com:6543/postgres"
USE_RAG=false
RAG_PROJECT=global
