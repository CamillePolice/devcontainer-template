#CLAUDE.md

# VS Code Personal Settings
.vscode/
*.code-workspace
.cursor/

# Editor Configuration (copied by devcontainer)
.editorconfig
.prettierrc
.prettierignore

# Git Hooks (optional, user-specific)
.pre-commit-config.yaml

# DevContainer Logs
.devcontainer/.log/
.devcontainer/scripts/project_status

