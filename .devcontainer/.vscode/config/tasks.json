{
    "version": "2.0.0",
    "tasks": [
        // !! Environment related 
        {
            "label": "Init env",
            "type": "shell",
            "command": ".devcontainer/scripts/lifecycle/init_env.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "Start docker",
            "type": "shell",
            "command": ".devcontainer/scripts/lifecycle/start_docker.sh",
            "options": {
                "cwd": "${workspaceFolder}"
            },
            "runOptions": {
                "runOn": "folderOpen"
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "dependsOn": "Init env"
        },
        // !! Tools
        {
            "label": "🧹 Clean Zone.Identifier Files",
            "type": "shell",
            "command": "find ${workspaceFolder} -type f -name '*:Zone.Identifier' -delete && echo '✅ Zone.Identifier files cleaned successfully!' || echo '❌ Failed to clean Zone.Identifier files'",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared",
                "showReuseMessage": false
            },
            "problemMatcher": []
        }
    ]
}