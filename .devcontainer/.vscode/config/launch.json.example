{
    // Use IntelliSense to learn about possible attributes.
    // Hover to view descriptions of existing attributes.
    // For more information, visit: https://go.microsoft.com/fwlink/?linkid=830387
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Listen for Xdebug [MAIN API]",
            "type": "php",
            "request": "launch",
            "port": 9003,
            "pathMappings": {
                "/app": "${workspaceFolder}/opvigil-api"
            },
            "xdebugSettings": {
                "max_data": 65535,
                "show_hidden": 1,
                "max_children": 100,
                "max_depth": 5
            },
            "hostname": "0.0.0.0",
            "log": true,
            "externalConsole": false,
            "ignore": [
                "**/vendor/**/*.php"
            ]
        },
        {
            "name": "Listen for Xdebug [HISTORIC API]",
            "type": "php",
            "request": "launch",
            "port": 9004,
            "pathMappings": {
                "/app": "${workspaceFolder}/opvigil-historic-api"
            },
            "xdebugSettings": {
                "max_data": 65535,
                "show_hidden": 1,
                "max_children": 100,
                "max_depth": 5
            },
            "hostname": "0.0.0.0",
            "log": true,
            "externalConsole": false,
            "ignore": [
                "**/vendor/**/*.php"
            ]
        },
        {
            "name": "Debug Chrome [Frontend]",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:11420",
            "webRoot": "${workspaceFolder}/opvigil-frontend",
            "sourceMaps": true,
            "userDataDir": "${workspaceFolder}/.vscode/chrome-debug-userdatadir",
            "runtimeArgs": [
                "--disable-web-security",
                "--disable-features=VizDisplayCompositor"
            ],
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/src/*",
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "*",
                "webpack:///./~/*": "${webRoot}/node_modules/*"
            }
        },
        {
            "name": "Debug Edge [Frontend]",
            "type": "msedge",
            "request": "launch",
            "url": "http://localhost:11420",
            "webRoot": "${workspaceFolder}/opvigil-frontend",
            "sourceMaps": true,
            "userDataDir": "${workspaceFolder}/.vscode/edge-debug-userdatadir",
            "runtimeArgs": [
                "--disable-web-security",
                "--disable-features=VizDisplayCompositor"
            ],
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/src/*",
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "*",
                "webpack:///./~/*": "${webRoot}/node_modules/*"
            }
        },
        {
            "name": "Debug Firefox [Frontend]",
            "type": "firefox",
            "request": "launch",
            "url": "http://localhost:11420",
            "webRoot": "${workspaceFolder}/opvigil-frontend",
            "firefoxExecutable": "/usr/bin/firefox",
            "profileDir": "${workspaceFolder}/.vscode/firefox-debug-profile"
        },
        {
            "name": "Debug Angular Tests",
            "type": "chrome",
            "request": "launch",
            "url": "http://localhost:9876/debug.html",
            "webRoot": "${workspaceFolder}/opvigil-frontend",
            "sourceMaps": true,
            "sourceMapPathOverrides": {
                "webpack:///./src/*": "${webRoot}/src/*",
                "webpack:///src/*": "${webRoot}/src/*",
                "webpack:///*": "*"
            },
            "preLaunchTask": "ng: test"
        }
    ],
    "compounds": [
        {
            "name": "Debug Full Stack",
            "configurations": [
                "Listen for Xdebug [MAIN API]",
                "Listen for Xdebug [HISTORIC API]",
                "Debug Chrome [Frontend]"
            ],
            "stopAll": true
        },
        {
            "name": "Debug APIs Only",
            "configurations": [
                "Listen for Xdebug [MAIN API]",
                "Listen for Xdebug [HISTORIC API]"
            ],
            "stopAll": true
        },
        {
            "name": "Debug All APIs",
            "configurations": [
                "Listen for Xdebug [MAIN API]",
                "Listen for Xdebug [HISTORIC API]",
            ],
            "stopAll": true
        }
    ]
}
