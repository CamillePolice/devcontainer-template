# ============================================================
# DevContainer Environment Variables
# Copy this file to .env and customize for your project
# !! .env is gitignored, .env.example is committed
# ============================================================

# ── Core ────────────────────────────────────────────────────
REMOTE_CONTAINERS=true
DEVCONTAINER=true
DEBIAN_FRONTEND=noninteractive
PROJECT_NAME=MY_PROJECT_NAME
WHICH_EDITOR=cursor|vscode

# ── Git / Terminal ───────────────────────────────────────────
USE_GIT_PROMPT=true

# ── Docker ──────────────────────────────────────────────────
USE_DOCKER_AUTOCOMPLETE=true

# ── VS Code ─────────────────────────────────────────────────
USE_VSCODE_CONFIG=true

# ── Claude Code ─────────────────────────────────────────────
USE_CLAUDE_CODE=true
CLAUDE_CODE_CHANNEL=latest
# Create empty .claude/ structure only (no clone). See .devcontainer/docs/claude-code.md — everything-claude-code is a great source for agents, skills, hooks, rules.
USE_CLAUDE=true
USE_CLAUDE_MARKETPLACE=true

# ── rtk (Rust Token Killer) ──────────────────────────────────
# Reduces LLM token consumption 60–90% via command output filtering
USE_RTK=true

# ── Ollama (local LLM) ───────────────────────────────────────
USE_OLLAMA=false
OLLAMA_REPO=CamillePolice/ollama
OLLAMA_DEFAULT_MODEL=qwen2.5-coder:7b
OLLAMA_GPU_ENABLED=auto
OLLAMA_KEEP_ALIVE=5m
OLLAMA_MEMORY_LIMIT=8G

# ── Repos to clone (workspace root) ───────────────────────────
# List of repositories to clone at the same level as .devcontainer.
# Short form: owner/repo (GitHub). Full URL: https://... or git@github.com:...
# Separator: comma or space. Example: https://github.com/CamillePolice/nas-docker
# For each clone: README is removed; CLAUDE.md, .claude, .vscode are added to that repo's .gitignore.
# REPO_URLS=https://github.com/CamillePolice/nas-docker

# ── RAG / Supabase ───────────────────────────────────────────
# RAG_DSN comes from your HOST ~/.zshrc, not here (contains password)
# export RAG_DSN="postgresql://postgres.xxx:xxx@aws-1-eu-west-1.pooler.supabase.com:6543/postgres"
USE_RAG=false
RAG_PROJECT=MY_PROJECT_NAME
